# =========================================================================
# FINANCEFLOW ENVIRONMENT VARIABLES
# (None of these are required to run the application locally!)
# =========================================================================

# GEMINI_API_KEY: Optional. Only required if using Gemini AI API features.
# You can leave this blank or as-is for local ledger tracking.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Optional. Used in Cloud production deployments.
# For local running, the app automatically defaults to http://localhost:3000.
APP_URL="MY_APP_URL"

